# Bulwark Configuration
# Copy to .env and fill in values as needed

# Optional: LLM endpoint for semantic detection (OpenAI-compatible)
BULWARK_LLM_ENDPOINT=
BULWARK_LLM_API_KEY=

# Optional: Default target agent URL
BULWARK_DEFAULT_TARGET=

# Optional: Report output directory
BULWARK_REPORT_DIR=./reports
